    # 计算共下调和共上调
    global common_down, common_up
    common_down = set()
    common_up = set()

    if len(cell_data) >= 2:
        common_down = find_common_regulated_genes(cell_data, 'down')
        common_up = find_common_regulated_genes(cell_data, 'up')
        print(f"\n📊 共下调基因: {len(common_down)} 个")
        if len(common_down) > 0:
            print(f"   示例: {', '.join(sorted(list(common_down))[:10])}")
        print(f"📊 共上调基因: {len(common_up)} 个")
        if len(common_up) > 0:
            print(f"   示例: {', '.join(sorted(list(common_up))[:10])}")

    print("\n" + "=" * 60)
    print("🎨 开始绘制火山图...")
    print("=" * 60)

    executed_count = 0
    for cell_name, keyword in cell_lines.items():
        matched_file = next((f for f in all_files if keyword in f and f.endswith(('.xls', '.xlsx', '.csv'))), None)

        if matched_file:
            full_path = os.path.join(data_dir, matched_file)
            plot_volcano(cell_name, full_path, common_down, common_up)
            executed_count += 1
        else:
            print(f"⚠️ 提示：在目录中未找到包含 '{keyword}' 的数据文件，跳过该细胞系。")

    if label_records:
        df_out = pd.DataFrame(label_records)

        # ===== Sheet1: 详细记录（按优先级排序）=====
        reason_order = {
            'Core gene (must show)': 0,
            'Pathway rep (Autophagy)': 1,
            'Pathway rep (mTOR)': 2,
            'Pathway rep (PI3K-Akt)': 3,
            'Pathway rep (NF-kappa B)': 4,
            'Pathway rep (KSHV)': 5,
            'High sig + pathway': 6,
            'High significance (score-ranked)': 7
        }
        df_out['sort_key'] = df_out['Selection_reason'].map(lambda x: next((v for k,v in reason_order.items() if k in x), 99))
        df_out = df_out.sort_values(['Cell', 'sort_key', 'Score'], ascending=[True, True, False])
        df_out = df_out.drop('sort_key', axis=1)

        # ===== Sheet2: 整理好的标签列表（按细胞系分上下调）=====
        summary_data = []
        for cell in df_out['Cell'].unique():
            cell_df = df_out[df_out['Cell'] == cell]
            up_genes = cell_df[cell_df['Direction'] == 'Up']['Gene'].tolist()
            dn_genes = cell_df[cell_df['Direction'] == 'Down']['Gene'].tolist()

            # 对齐上下调列表长度
            max_len = max(len(up_genes), len(dn_genes))
            up_genes += [''] * (max_len - len(up_genes))
            dn_genes += [''] * (max_len - len(dn_genes))

            for i in range(max_len):
                summary_data.append({
                    'Cell': cell if i == 0 else '',
                    'Up_regulated_labels': up_genes[i],
                    'Down_regulated_labels': dn_genes[i]
                })

        df_summary = pd.DataFrame(summary_data)

        # ===== 输出多Sheet Excel =====
        out_excel = os.path.join(data_dir, "Priority_Genes_Summary.xlsx")
        with pd.ExcelWriter(out_excel, engine='openpyxl') as writer:
            df_out.to_excel(writer, sheet_name='Detailed_Records', index=False)
            df_summary.to_excel(writer, sheet_name='Label_List', index=False)

        print(f"\n📊 优先级基因汇总表已保存：{os.path.basename(out_excel)}")
        print(f"   - Sheet1: Detailed_Records（详细记录）")
        print(f"   - Sheet2: Label_List（整理好的标签列表）")

    if executed_count == 0:
        print("❌ 错误：工作目录中未匹配到任何指定细胞系的数据，请检查输入文件名！")
    else:
        print(f"\n✨ 全部任务顺利完成！成功绘制了 {executed_count} 组火山图。")
