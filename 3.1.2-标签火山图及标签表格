    }

    all_files = os.listdir(data_dir)

    # 第一步：读取所有细胞系数据，计算共下调/共上调
    print("=" * 60)
    print("🔍 正在读取数据并计算共下调/共上调基因...")
    print("=" * 60)

    cell_data = {}
    for cell_name, keyword in cell_lines.items():
        matched_file = next((f for f in all_files if keyword in f and f.endswith(('.xls', '.xlsx', '.csv'))), None)
        if matched_file:
            full_path = os.path.join(data_dir, matched_file)
            if full_path.endswith(('.xls', '.xlsx')):
                df_raw = pd.read_excel(full_path)
            else:
