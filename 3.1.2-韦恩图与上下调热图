# ================= 2. 数据读取与清理 =================
def load_clean_deg(filename):
    filepath = os.path.join(BASE_DIR, filename)
    df = pd.read_excel(filepath)
    if 'Name' in df.columns:
        df.rename(columns={'Name': 'Gene_Name'}, inplace=True)
    if 'padj' in df.columns:
        df.rename(columns={'padj': 'FDR'}, inplace=True)
    clean_df = df[['Gene_Name', 'log2FoldChange', 'FDR']].copy()
    clean_df.dropna(subset=['Gene_Name'], inplace=True)
    clean_df['Gene_Name'] = clean_df['Gene_Name'].astype(str).str.strip()
    clean_df = clean_df[~clean_df['Gene_Name'].isin(['-', 'nan', 'NaN', ''])]
    clean_df['FDR'] = clean_df['FDR'].fillna(1.0)
    clean_df['log2FoldChange'] = clean_df['log2FoldChange'].fillna(0)
    return clean_df

print("📂 加载数据...")
