if __name__ == '__main__':
    plot_pca()
    plot_venn_combined()
    
    # 准备热图基因列表
    co_up, co_down, co_up_top100 = get_combined_gene_lists()
    print("\n🔥 生成蓝‑白‑红热图...")
    draw_heatmap_labels_right(co_up,    "显著公共上调组 (含TNIP3)",      "Co_Up_Heatmap")
    draw_heatmap_labels_right(co_down,  "显著公共下调组 (排除TNIP3)",    "Co_Down_Heatmap")
    draw_heatmap_labels_right(co_up_top100, "显著公共上调 TOP100 (含TNIP3)", "Top100_Up_Heatmap")
    
    plot_boxplots()
    print("\n🎉 全部完成！所有图片已保存至：", OUTPUT_DIR)
