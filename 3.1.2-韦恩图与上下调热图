# ================= 4. 两张 Venn 图（共上调 / 共下调）=================
def plot_venn_combined():
    print("🔗 绘制共上调/共下调 Venn 图...")
    
    def get_sig_genes(df, direction='up'):
        if direction == 'up':
            return set(df[(df['FDR'] < 0.05) & (df['log2FoldChange'] > 1)]['Gene_Name'])
        else:
            return set(df[(df['FDR'] < 0.05) & (df['log2FoldChange'] < -1)]['Gene_Name'])
    
    up_ib6 = get_sig_genes(deg_ib6, 'up')
    up_bl  = get_sig_genes(deg_bl, 'up')
    down_ib6 = get_sig_genes(deg_ib6, 'down')
    down_bl  = get_sig_genes(deg_bl, 'down')
    
    # 上调 Venn
    fig_up, ax_up = plt.subplots(figsize=(5, 5))
    v_up = venn2([up_ib6, up_bl], set_labels=('iSLK-BAC16', 'BCBL-1'), ax=ax_up)
    v_up.get_patch_by_id('10').set_color(C_MAGENTA)   # 仅 iSLK-BAC16
    v_up.get_patch_by_id('01').set_color(C_YELLOW)    # 仅 BCBL-1
    v_up.get_patch_by_id('11').set_color('#D95F02')   # 交集（橙红）
    plt.title("Up-regulated genes (FDR<0.05, log2FC>1)", fontsize=12, fontweight='bold')
    plt.tight_layout()
    plt.savefig(os.path.join(OUTPUT_DIR, "Venn_Up_Combined.pdf"), dpi=300)
    plt.close()
    
    # 下调 Venn
    fig_down, ax_down = plt.subplots(figsize=(5, 5))
    v_down = venn2([down_ib6, down_bl], set_labels=('iSLK-BAC16', 'BCBL-1'), ax=ax_down)
    v_down.get_patch_by_id('10').set_color(C_TEAL)     # 仅 iSLK-BAC16
    v_down.get_patch_by_id('01').set_color('#457B9D')  # 仅 BCBL-1
    v_down.get_patch_by_id('11').set_color('#2C7BB6')  # 交集（蓝色）
    plt.title("Down-regulated genes (FDR<0.05, log2FC<-1)", fontsize=12, fontweight='bold')
    plt.tight_layout()
    plt.savefig(os.path.join(OUTPUT_DIR, "Venn_Down_Combined.pdf"), dpi=300)
    plt.close()
    
    print(f"   共上调基因数: {len(up_ib6 & up_bl)}")
    print(f"   共下调基因数: {len(down_ib6 & down_bl)}")

# ================= 5. 热图（蓝‑白‑红，右侧标签，细边框，水平样本标签）=================
def build_expression_matrix():
    """构建 BCBL-1 和 iSLK-BAC16 的四列均值矩阵（0h / 72h）"""
    fpkm_cols = [c for c in expr_df.columns if 'fpkm' in c.lower()]
    valid_fpkm_cols = [c for c in fpkm_cols if c.split('_')[0] in ['IB6CON', 'IB6T', 'BLCON', 'BLT']]
    sub_expr = expr_df[['Name'] + valid_fpkm_cols].copy()
    grouped_expr = sub_expr.groupby('Name').mean(numeric_only=True)
    
    final_df = pd.DataFrame(index=grouped_expr.index)
    label_map_short = {
        'BLCON': 'BCBL-1 (0h)',
        'BLT': 'BCBL-1 (72h)',
        'IB6CON': 'iSLK-BAC16 (0h)',
        'IB6T': 'iSLK-BAC16 (72h)'
    }
    for prefix, label in label_map_short.items():
        cols = [c for c in grouped_expr.columns if c.startswith(prefix)]
        if cols:
            final_df[label] = grouped_expr[cols].mean(axis=1)
    desired_order = ['BCBL-1 (0h)', 'BCBL-1 (72h)', 'iSLK-BAC16 (0h)', 'iSLK-BAC16 (72h)']
    final_df = final_df[desired_order]
    return np.log2(final_df + 1), final_df.index

def draw_heatmap_labels_right(gene_list, title_tag, filename_save):
    if not gene_list:
        print(f"⚠️ 跳过 {title_tag}：基因列表为空")
        return
    log2_matrix, all_genes = build_expression_matrix()
    data = log2_matrix.loc[gene_list].copy()
    # 行 Z-score
    data = data.sub(data.mean(axis=1), axis=0).div(data.std(axis=1), axis=0)
    data = data.fillna(0).replace([np.inf, -np.inf], 0)
    
    n_genes, n_samples = data.shape
    if n_genes == 0:
        return
    
    # 行聚类
    if n_genes > 1:
        row_linkage = linkage(pdist(data.values, metric='euclidean'), method='ward')
        row_order = leaves_list(row_linkage)
    else:
        row_order = [0]
    data_clustered = data.iloc[row_order]
    gene_labels = data_clustered.index.tolist()
    
    fig_height = max(5, min(28, n_genes * 0.3))
    fontsize_y = max(6, min(12, fig_height * 72 / (n_genes * 1.3)))
    
    fig = plt.figure(figsize=(8.5, fig_height))
    gs = GridSpec(1, 2, width_ratios=[0.18, 0.82], wspace=0.03)
    ax_dendro = fig.add_subplot(gs[0, 0])
    ax_heatmap = fig.add_subplot(gs[0, 1])
    
    # 聚类树（细线半透明）
    if n_genes > 1:
        dendrogram(row_linkage, ax=ax_dendro, orientation='left',
                   above_threshold_color='#2c3e50', color_threshold=0.7 * max(row_linkage[:,2]) if len(row_linkage) > 0 else None,
                   no_labels=True)
        for coll in ax_dendro.collections:
            coll.set_linewidth(0.5)
            coll.set_alpha(0.3)
        for line in ax_dendro.lines:
            line.set_linewidth(0.5)
            line.set_alpha(0.3)
    ax_dendro.set_xticks([])
    ax_dendro.set_yticks([])
    for spine in ax_dendro.spines.values():
        spine.set_visible(False)
    
    # 热图主体
    im = ax_heatmap.imshow(data_clustered.values, cmap=CMAP_HEATMAP, aspect='auto',
                           vmin=-2.5, vmax=2.5, interpolation='nearest')
    ax_heatmap.yaxis.set_ticks_position('right')
    ax_heatmap.yaxis.set_label_position('right')
    ax_heatmap.set_xticks(range(n_samples))
    ax_heatmap.set_xticklabels(data.columns, fontsize=9, fontname='Arial', rotation=0, ha='center')
    ax_heatmap.xaxis.set_tick_params(pad=4)
    ax_heatmap.set_yticks(range(n_genes))
    ax_heatmap.set_yticklabels(gene_labels, fontsize=fontsize_y, fontname='Arial', style='italic')
    ax_heatmap.tick_params(axis='y', left=False, right=True, labelright=True, pad=2)
    ax_heatmap.tick_params(axis='x', bottom=False)
    for spine in ax_heatmap.spines.values():
        spine.set_visible(True)
        spine.set_color('#cccccc')
        spine.set_linewidth(0.5)
    ax_heatmap.set_ylim(n_genes - 0.5, -0.5)
    
    # 色条（顶部）
    fig.canvas.draw()
    bbox = ax_heatmap.get_position()
    cbar_ax = fig.add_axes([bbox.x0, 0.92, bbox.width, 0.02])
    cbar = fig.colorbar(im, cax=cbar_ax, orientation='horizontal')
    cbar.set_label("Z-score", fontsize=9, fontname='Arial', labelpad=2)
    cbar.ax.tick_params(labelsize=8)
    cbar.outline.set_visible(False)
    fig.subplots_adjust(top=0.92)
    
    plt.savefig(os.path.join(OUTPUT_DIR, f"Fig3_{filename_save}.pdf"), dpi=300, bbox_inches='tight')
    plt.savefig(os.path.join(OUTPUT_DIR, f"Fig3_{filename_save}.svg"), dpi=300, bbox_inches='tight')
    plt.close(fig)
    print(f"✅ {title_tag} | 基因数={n_genes} | 高度={fig_height:.1f}in | 字体={fontsize_y:.1f}pt")

# 准备热图的基因列表（公共上调/下调/TOP100）
def get_combined_gene_lists():
    sig_up_ib6 = set(deg_ib6[(deg_ib6['FDR']<0.05) & (deg_ib6['log2FoldChange']>1)]['Gene_Name'])
    sig_up_bl  = set(deg_bl[(deg_bl['FDR']<0.05) & (deg_bl['log2FoldChange']>1)]['Gene_Name'])
    co_up_list = list(sig_up_ib6.intersection(sig_up_bl))
    if "TNIP3" not in co_up_list and "TNIP3" in deg_ib6['Gene_Name'].values:
        co_up_list.append("TNIP3")
    
    sig_down_ib6 = set(deg_ib6[(deg_ib6['FDR']<0.05) & (deg_ib6['log2FoldChange']<-1)]['Gene_Name'])
    sig_down_bl  = set(deg_bl[(deg_bl['FDR']<0.05) & (deg_bl['log2FoldChange']<-1)]['Gene_Name'])
    co_down_list = list(sig_down_ib6.intersection(sig_down_bl))
    if "TNIP3" in co_down_list:
        co_down_list.remove("TNIP3")
    
    # TOP100 共上调
    up_ib6_detail = deg_ib6[deg_ib6['Gene_Name'].isin(co_up_list)][['Gene_Name','log2FoldChange']].rename(columns={'log2FoldChange':'FC_ib6'})
    up_bl_detail  = deg_bl[deg_bl['Gene_Name'].isin(co_up_list)][['Gene_Name','log2FoldChange']].rename(columns={'log2FoldChange':'FC_bl'})
    up_merged = pd.merge(up_ib6_detail, up_bl_detail, on='Gene_Name', how='inner')
    up_merged['avg_log2FC'] = (up_merged['FC_ib6'] + up_merged['FC_bl']) / 2
    up_merged = up_merged.sort_values('avg_log2FC', ascending=False)
    co_up_top100 = up_merged['Gene_Name'].head(100).tolist()
    if "TNIP3" in co_up_top100 and "TNIP3" not in co_up_top100:
        co_up_top100 = co_up_top100[:-1] + ["TNIP3"]
    
    return co_up_list, co_down_list, co_up_top100

# ================= 6. 箱线图（增加 CADM2, RAP1GAP）=================
def plot_boxplots():
    print("📊 绘制箱线图...")
    available_genes = [g for g in TARGET_GENES_POOL if g in expr_df['Name'].values]
    # 优先展示 TNIP3 + 前几个基因，保证 CADM2 和 RAP1GAP 出现
    plot_list = []
    if "TNIP3" in available_genes:
        plot_list.append("TNIP3")
        available_genes.remove("TNIP3")
    # 确保新增基因一定在图中
    for new_g in ["CADM2", "RAP1GAP"]:
        if new_g in available_genes:
            plot_list.append(new_g)
            available_genes.remove(new_g)
    plot_list.extend(available_genes[:2])  # 再取两个其他基因
    
    if not plot_list:
        return
    
    fpkm_cols = [c for c in expr_df.columns if 'fpkm' in c.lower()]
    fig, axes = plt.subplots(1, len(plot_list), figsize=(4.5 * len(plot_list), 6))
    if len(plot_list) == 1:
        axes = [axes]
    
    order_keys = ['IKCON', 'IKT', 'IB6CON', 'IB6T', 'BLCON', 'BLT']
    order_labels = [LABEL_MAP[k] for k in order_keys]
    
    for ax, gene in zip(axes, plot_list):
        gene_row = expr_df[expr_df['Name'] == gene].iloc[0]
        plot_data = []
        for col in fpkm_cols:
            val = gene_row[col]
            cond_key = col.split('_')[0]
            if cond_key in LABEL_MAP:
                plot_data.append({'Condition': LABEL_MAP[cond_key], 'FPKM': float(val)})
        df_plot = pd.DataFrame(plot_data)
        sns.boxplot(x='Condition', y='FPKM', data=df_plot, order=order_labels,
                    palette=GROUP_COLORS, ax=ax, width=0.5, boxprops=dict(alpha=0.7))
        sns.stripplot(x='Condition', y='FPKM', data=df_plot, order=order_labels,
                      color="black", size=5, jitter=True, ax=ax)
        ax.set_title(f"{gene}", fontsize=15, fontweight='bold', style='italic')
        ax.set_ylabel("Expression (FPKM)", fontsize=12)
        ax.set_xlabel("")
        ax.set_xticklabels(order_labels, rotation=45, ha='right', fontsize=10)
        sns.despine(ax=ax)
    plt.tight_layout()
    plt.savefig(os.path.join(OUTPUT_DIR, "Fig3E_Selected_Genes_Boxplot.pdf"), dpi=300)
    plt.close()

