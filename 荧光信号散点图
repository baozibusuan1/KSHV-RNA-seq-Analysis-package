        svg.append("line")
            .attr("class", "zero-line")
            .attr("x1", 0)
            .attr("x2", width)
            .attr("y1", yScale(0))
            .attr("y2", yScale(0));

        // 创建颜色比例尺 - 反转红蓝配色
        const colorScale = d3.scaleDiverging(d3.interpolateRdBu)
            .domain([3, 0, -8]); // 反转域的顺序

        // 绘制散点
        svg.selectAll(".dot")
            .data(geneData)
            .enter().append("circle")
            .attr("class", "dot")
            .attr("cx", (d, i) => xScale(i))
            .attr("cy", d => yScale(d.value))
            .attr("r", 3.5)
            .style("fill", d => colorScale(d.value))
            .style("stroke", "#2c3e50")
            .style("stroke-width", 0.8);

        // 找出上下调最显著的基因
        const topDown = [...geneData].sort((a, b) => a.value - b.value).slice(0, 10);
        const topUp = [...geneData].sort((a, b) => b.value - a.value).slice(0, 10);

        // 改进的标签布局 - 确保标签不遮挡散点且在画幅内
        function createProximityLabels(genes, isUp) {
            const labels = [];
            const occupiedPositions = new Set();
            const dotRadius = 4; // 散点半径
            
            // 按x位置排序
            const sortedGenes = [...genes].sort((a, b) => {
                const indexA = geneData.findIndex(d => d.name === a.name);
                const indexB = geneData.findIndex(d => d.name === b.name);
                return indexA - indexB;
            });
            
            sortedGenes.forEach((gene, index) => {
                const geneIndex = geneData.findIndex(d => d.name === gene.name);
                const x = xScale(geneIndex);
                const y = yScale(gene.value);
                
                // 标签位置 - 靠近数据点
                const offsetX = isUp ? -35 : 35; // 上调在左，下调在右
                const labelX = x + offsetX;
                
                // 检查标签是否超出画幅边界
                const labelWidth = 50;
                const labelHeight = 14;
                let adjustedLabelX = labelX;
                
                // 确保标签在画幅内
                if (isUp && labelX - labelWidth/2 < -margin.left + 10) {
                    adjustedLabelX = -margin.left + 10 + labelWidth/2;
                } else if (!isUp && labelX + labelWidth/2 > width + margin.right - 10) {
                    adjustedLabelX = width + margin.right - 10 - labelWidth/2;
                }
                
                // 寻找合适的垂直位置
                let bestY = y;
                let level = 0;
                let foundPosition = false;
                
                while (!foundPosition && level < 15) {
                    const testY = y + (level % 2 === 0 ? level * 12 : -level * 12);
                    
                    // 检查这个位置是否可用
                    let positionAvailable = true;
                    
                    // 1. 检查是否与其他标签重叠
                    for (let occupied of occupiedPositions) {
                        const [occupiedX, occupiedY] = occupied.split(',').map(Number);
                        if (Math.abs(adjustedLabelX - occupiedX) < 45 && Math.abs(testY - occupiedY) < 18) {
                            positionAvailable = false;
                            break;
                        }
                    }
                    
                    // 2. 检查是否遮挡散点
                    if (positionAvailable) {
                        for (let dot of geneData) {
                            const dotIndex = geneData.findIndex(d => d.name === dot.name);
                            const dotX = xScale(dotIndex);
                            const dotY = yScale(dot.value);
                            
                            // 计算标签边界
                            const labelLeft = adjustedLabelX - labelWidth/2;
                            const labelRight = adjustedLabelX + labelWidth/2;
                            const labelTop = testY - labelHeight/2;
                            const labelBottom = testY + labelHeight/2;
                            
                            // 检查散点是否在标签范围内
                            if (dotX >= labelLeft && dotX <= labelRight && 
                                dotY >= labelTop && dotY <= labelBottom) {
                                positionAvailable = false;
                                break;
                            }
                        }
                    }
                    
                    // 3. 检查是否在画幅内
                    if (positionAvailable) {
                        if (testY - labelHeight/2 < 0 || testY + labelHeight/2 > height) {
                            positionAvailable = false;
                        }
                    }
                    
                    if (positionAvailable) {
                        bestY = testY;
                        foundPosition = true;
                        occupiedPositions.add(`${adjustedLabelX},${bestY}`);
                    }
                    
                    level++;
                }
                
                labels.push({
                    gene,
                    x,
                    y,
                    labelX: adjustedLabelX,
                    labelY: bestY,
                    isUp
                });
            });
            
            return labels;
        }

        // 创建标签
        const downLabels = createProximityLabels(topDown, false);
        const upLabels = createProximityLabels(topUp, true);

        // 绘制下调基因标签（右侧）- 字体黑色，边框蓝色
        downLabels.forEach(item => {
            // 短连接线 - 蓝色
            svg.append("line")
