            svg.append("rect")
                .attr("class", "label-bg down-label-bg")
                .attr("x", item.labelX - 25)
                .attr("y", item.labelY - 7)
                .attr("width", 50)
                .attr("height", 14)
                .attr("rx", 3);

            // 基因名称 - 黑色
            svg.append("text")
                .attr("class", "gene-label")
                .attr("x", item.labelX)
                .attr("y", item.labelY + 2)
                .attr("text-anchor", "middle")
                .text(item.gene.name);
        });

        // 绘制上调基因标签（左侧）- 字体黑色，边框红色
        upLabels.forEach(item => {
            // 短连接线 - 红色
            svg.append("line")
                .attr("class", "connector")
                .attr("x1", item.x - 4)
                .attr("y1", item.y)
                .attr("x2", item.labelX + 12)
                .attr("y2", item.labelY)
                .style("stroke", "#e74c3c"); // 红色

            // 背景框 - 红色边框
            svg.append("rect")
                .attr("class", "label-bg up-label-bg")
                .attr("x", item.labelX - 25)
                .attr("y", item.labelY - 7)
                .attr("width", 50)
                .attr("height", 14)
                .attr("rx", 3);

            // 基因名称 - 黑色
            svg.append("text")
                .attr("class", "gene-label")
                .attr("x", item.labelX)
                .attr("y", item.labelY + 2)
                .attr("text-anchor", "middle")
                .text(item.gene.name);
        });

